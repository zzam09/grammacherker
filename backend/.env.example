# ============================================================
#  GrammarCheck — Backend Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ============================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/grammarcheck

# Server port (default: 3001)
PORT=3001

# Node environment: development | production
NODE_ENV=development

# Optional: OpenAI API key
# If set, the app will use GPT-4o-mini for richer grammar analysis.
# If omitted, a built-in rule-based checker is used automatically.
# OPENAI_API_KEY=sk-...
